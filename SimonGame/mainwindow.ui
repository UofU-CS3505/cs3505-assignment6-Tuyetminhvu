       </property>
       <property name="styleSheet">
        <string notr="true">#startButton {
    background-color: black;
    color: white;
    border: 1px black;    
    border-radius: 3px;     
    font-weight: bold;     
}

#startButton:hover {
    background-color: #333333;
}

#startButton:pressed {
    background-color: #555555;
}

#startButton:disabled {
    background-color: #333333;  
    color: #777777;           
    border: 2px solid #333333;  
}</string>
